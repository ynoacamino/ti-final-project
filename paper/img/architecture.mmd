%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#6C63FF', 'primaryTextColor': '#fff', 'fontSize': '13px', 'fontFamily': 'arial'}}}%%

graph TB
    subgraph CLIENT["Mobile Client (Flutter)"]
        direction LR
        A1["App Flutter<br/>Riverpod + GoRouter"]:::client
        A2["Light Theme<br/>(Customers)"]:::clientAlt
        A3["Dark Theme<br/>(Admins)"]:::clientAlt
    end

    subgraph API["REST API (Bun + Hono)"]
        direction LR
        B1["Auth<br/>JWT + bcrypt"]:::api
        B2["Catalog<br/>CRUD Products"]:::api
        B3["Cart<br/>Sessions + Items"]:::api
        B4["Orders<br/>Stripe + Webhooks"]:::api
        B5["Dashboard<br/>Metrics + Charts"]:::api
        B6["Inventory<br/>Stock + Alerts"]:::api
    end

    subgraph DB["Storage Layer"]
        direction LR
        C1[("SQLite<br/>(Drizzle ORM)")]:::storage
        C2[("Cloudflare R2<br/>(Images)")]:::storage
        C3[("Stripe<br/>(Sandbox Payments)")]:::storage
    end

    A1 --> B1
    A1 --> B2
    A1 --> B3
    A1 --> B4
    A1 --> B5
    A1 --> B6

    B1 --> C1
    B2 --> C1
    B2 --> C2
    B3 --> C1
    B4 --> C1
    B4 --> C3
    B5 --> C1
    B6 --> C1

    classDef client fill:#6C63FF,stroke:#5A52D5,color:#fff,stroke-width:2px,rx:10
    classDef clientAlt fill:#9B93E8,stroke:#7B72CC,color:#fff,stroke-width:2px,rx:20
    classDef api fill:#FF6B6B,stroke:#E55555,color:#fff,stroke-width:2px,rx:4
    classDef storage fill:#4ECDC4,stroke:#3BB5AD,color:#fff,stroke-width:2px
